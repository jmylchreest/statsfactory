{
  "schema_version": 1,
  "name": "bash",
  "version": "",
  "c_symbol": "tree_sitter_bash",
  "source_repo": "tree-sitter/tree-sitter-bash",
  "source_tag": "v0.25.1",
  "meta": {
    "extensions": [".sh", ".bash", ".zsh"],
    "filenames": [
      ".bashrc",
      ".bash_profile",
      ".bash_logout",
      ".profile",
      ".zshrc",
      ".zprofile"
    ],
    "shebangs": ["bash", "sh", "zsh"],
    "aliases": ["sh", "shell"]
  },
  "queries": {
    "tags": "(function_definition name: (word) @name) @definition.function"
  },
  "complexity": {
    "func_node_types": ["function_definition"],
    "branch_types": [
      "if_statement",
      "elif_clause",
      "for_statement",
      "while_statement",
      "case_item",
      "binary_expression"
    ],
    "name_field": "name"
  },
  "tokenisation": {
    "identifier_types": ["word", "variable_reference"],
    "literal_types": ["string", "raw_string", "number"],
    "keyword_types": ["if", "else", "for", "while", "case", "function"]
  },
  "entrypoints": {
    "symbols": [
      {
        "name": "main",
        "kind": "function",
        "type": "main",
        "label": "Bash main function"
      },
      {
        "name": "usage",
        "kind": "function",
        "type": "cli_root",
        "label": "Bash usage/help function"
      }
    ],
    "file_patterns": [
      {
        "file_match": "*.sh",
        "content": "^#!/bin/(ba)?sh",
        "type": "main",
        "label": "Shell script entry point"
      },
      {
        "file_match": "*.sh",
        "content": "^main \"\\$@\"",
        "type": "main",
        "label": "Bash main dispatch pattern"
      },
      {
        "file_match": "entrypoint.sh",
        "type": "main",
        "label": "Docker entrypoint script"
      },
      {
        "file_match": "install.sh",
        "type": "init",
        "label": "Installation script"
      }
    ]
  }
}
