{
  "name": "@statsfactory/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for statsfactory anonymous event telemetry",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jmylchreest/statsfactory",
    "directory": "packages/sdk-ts"
  },
  "keywords": ["analytics", "telemetry", "statsfactory", "privacy"]
}
