# Local development variables.
# Copy this file to .dev.vars (which is gitignored).
#
# ── Database ─────────────────────────────────────────────
# D1 is the database backend. In local dev, `wrangler dev` provides a
# local D1 binding automatically (miniflare SQLite). No env vars needed.
#
# ── Dev mode ─────────────────────────────────────────────
# Enables dev bypass for dashboard auth (no Cloudflare Access needed).
STATSFACTORY_DEV=1

# ── Cloudflare Access (production only) ──────────────────
# When set, the cfAccessAuth middleware requires a valid
# Cf-Access-Authenticated-User-Email header on query and
# management routes.
# When absent (and STATSFACTORY_DEV=1), auth is bypassed with dev@localhost.
#
# For production, set via wrangler secrets:
#   wrangler secret put CF_ACCESS_TEAM_DOMAIN
#
# CF_ACCESS_TEAM_DOMAIN=your-team.cloudflareaccess.com
