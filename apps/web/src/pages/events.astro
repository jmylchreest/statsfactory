---
import Dashboard from "../layouts/Dashboard.astro";
import EventExplorer from "../components/EventExplorer";
---

<Dashboard title="Event Explorer — statsfactory" activePage="events">
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-bold tracking-tight">Event Explorer</h1>
      <p class="text-gray-400 text-sm mt-1">Select an event type, explore dimensions, and break down by value</p>
    </div>
    <EventExplorer client:only="react" />
  </div>
</Dashboard>
